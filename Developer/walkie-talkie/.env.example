# Mesh Environment Variables
# Copy this to .env and edit as needed

# Server Config
PORT=8080
PUBLIC_URL=https://trymesh.chat

# Security
# Optional: protect admin endpoints with a secret
ADMIN_CLAIM_SECRET=your-secret-here
# Optional: restrict CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://trymesh.chat

# Google OAuth (Auth → Google in Cloud Console)
# GOOGLE_CLIENT_ID=your-google-client-id

# Stripe Billing (Stripe Dashboard → Payments)
# STRIPE_PRO_LINK=https://buy.stripe.com/xxx
# STRIPE_TEAM_LINK=https://buy.stripe.com/yyy
# STRIPE_WEBHOOK_SECRET=whsec_...

# Analytics (PostHog Dashboard)
# POSTHOG_KEY=phc_...

# Room Config
# Optional: pre-create rooms on startup (comma-separated)
DEFAULT_ROOMS=mesh01,mesh02,engineering
